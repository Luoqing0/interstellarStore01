<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     星际商店 - 侧边栏配置
     看板娘/问候语/每日折扣/新闻公告/背景故事/黑名单
     可通过修改此XML自定义内容
     AI 辅助生成

     多看板娘随机说明：
     - <mascotDefNames> 中列出所有可用的 StarStore_MascotDef defName
     - 每次打开商店会从中随机选择一位看板娘
     - 若该看板娘配置了 <greetings>，则使用其独立问候语池
     - 若 mascotDefNames 为空，则回退到旧字段 mascotTexturePath + greetings
     - 详见 Docs/看板娘配置说明.md
     ============================================================ -->
<Defs>
  <StarStore_SidebarConfigDef>
    <defName>StarStore_DefaultSidebar</defName>
    <label>默认侧边栏配置</label>
    <description>星际商店左侧侧边栏内容配置</description>

    <!-- 侧边栏标题 -->
    <sidebarTitle>星际商报</sidebarTitle>

    <!-- 旧单一看板娘图片路径（未配置 mascotDefNames 时生效） -->
    <!-- <mascotTexturePath>UI/starstore_mascot</mascotTexturePath> -->

    <!-- 多个看板娘 defName 列表（每次打开商店随机选一个） -->
    <mascotDefNames>
      <li>StarStore_Mascot_Default</li>
      <li>StarStore_Mascot_Robot</li>
      <li>StarStore_Mascot_Catgirl</li>
    </mascotDefNames>

    <!-- 随机问候语列表（未配置看板娘 Def 时的兼容字段） -->
    <greetings>
      <li>欢迎光临星际商店，今天需要些什么？</li>
      <li>好久不见，旅行者！新货已到，进来看看？</li>
      <li>银河系最优惠的价格，就在这里！</li>
      <li>星际商店，您的太空贸易伙伴。</li>
      <li>风尘仆仆的旅人啊，休息一下再上路吧。</li>
      <li>今日特惠，错过等一年！</li>
      <li>无论您在哪个星系，我们都在您身边。</li>
      <li>今天小人的心情值怎么样了？</li>
      <li>要来一些鼠条吗？</li>
    </greetings>

    <!-- 是否使用随机类别+随机物品的每日折扣（true 时 dailyDiscountThingDefs 失效） -->
    <useRandomCategoryDiscount>true</useRandomCategoryDiscount>

    <!-- 每日折扣物品 defName 列表（关闭随机折扣时使用） -->
    <dailyDiscountThingDefs>
      <li>Gun_Revolver</li>
      <li>Gun_PumpShotgun</li>
      <li>Gun_BoltActionRifle</li>
      <li>Gun_ChainShotgun</li>
      <li>MeleeWeapon_Knife</li>
      <li>MeleeWeapon_Club</li>
      <li>MeleeWeapon_Gladius</li>
      <li>MeleeWeapon_LongSword</li>
      <li>Apparel_ArmorPlate</li>
      <li>Apparel_FlakVest</li>
      <li>Apparel_HelmetAdvanced</li>
      <li>MedicineUltratech</li>
      <li>MedicineIndustrial</li>
      <li>ComponentIndustrial</li>
      <li>ComponentSpacer</li>
    </dailyDiscountThingDefs>

    <!-- 折扣比例（0.0~1.0 之间，0.8 表示8折） -->
    <discountPercent>0.8</discountPercent>

    <!-- 折扣黑名单：这些 ThingDef defName 不会成为每日折扣物品 -->
    <discountBlacklist>
      <li>Silver</li>
    </discountBlacklist>

    <!-- 折扣分类黑名单：这些分类 Key 不会进入每日折扣候选 -->
    <discountCategoryBlacklist>
      <!-- <li>StarStore_Cat_Misc</li> -->
    </discountCategoryBlacklist>

    <!-- 是否将礼包内固定物品排除在每日折扣候选池之外 -->
    <excludeBundleItemsFromDiscount>true</excludeBundleItemsFromDiscount>

    <!-- 新闻公告列表（基于游戏内日期随机选取） -->
    <newsList>
      <li>银河联邦开放新的贸易航线，星际物流效率提升 15%</li>
      <li>边缘星域发现新型稀有矿物，价格波动剧烈</li>
      <li>星际海盗活动频繁，请各殖民地注意防御</li>
      <li>银河贸易协会发布新一季贸易指南</li>
      <li>机械族在边境星域的活动有所增加</li>
      <li>新的超光速航道即将开通，星际旅行时间将缩短</li>
      <li>银河交易所推出全新交易系统，操作更便捷</li>
      <li>香料航线恢复通航，异域香料价格预计下降</li>
    </newsList>

    <!-- 背景故事文本 -->
    <backstory>
星际商店创立于银河历 3047 年，由传奇商人"星语者"洛青创办。起初只是一艘小型商船，在边缘星域之间穿梭贸易。经过数十年的发展，如今已成为银河系最大的跨星系贸易网络之一。

我们的商店遍布银河各个角落，从繁华的核心星域到荒凉的边缘世界，无论您身处何地，都可以通过星际商店获取所需的一切。

"控制财富，一键进货"——这是我们不变的经营理念。
    </backstory>
  </StarStore_SidebarConfigDef>
</Defs>
