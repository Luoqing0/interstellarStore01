<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- ============================================================
       星际商店 - 商人定义
       定义商店出售哪些物品、价格乘数、交易条件等
       玩家可以在此文件中自由添加/修改物品
       ============================================================ -->

  <TraderKindDef>
    <defName>StarStore_Trader</defName>
    <label>星际商店</label>
    <description>来自遥远星系的综合商店</description>
    <!-- 不关联派系，独立存在 -->
    
    <!-- 库存生成器：定义商店出售的物品 -->
    <stockGenerators>
      <!-- ===== 基础资源 ===== -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Steel</thingDef>
        <countRange>500~2000</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>WoodLog</thingDef>
        <countRange>300~1000</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>ComponentIndustrial</thingDef>
        <countRange>50~200</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>ComponentSpacer</thingDef>
        <countRange>10~50</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Plasteel</thingDef>
        <countRange>50~200</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Gold</thingDef>
        <countRange>10~50</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Uranium</thingDef>
        <countRange>30~100</countRange>
      </li>

      <!-- ===== 食品 ===== -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>MealSimple</thingDef>
        <countRange>30~100</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MealFine</thingDef>
        <countRange>10~50</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MealLavish</thingDef>
        <countRange>5~20</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MealSurvivalPack</thingDef>
        <countRange>10~30</countRange>
      </li>

      <!-- ===== 药品 ===== -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>MedicineIndustrial</thingDef>
        <countRange>20~80</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MedicineUltratech</thingDef>
        <countRange>5~20</countRange>
      </li>
      <!-- GlitterWorldMedicine 已移除，原版不存在此 Def -->

      <!-- ===== 武器 ===== -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Gun_Revolver</thingDef>
        <countRange>3~10</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Gun_Autopistol</thingDef>
        <countRange>3~10</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Gun_AssaultRifle</thingDef>
        <countRange>2~8</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Gun_ChargeRifle</thingDef>
        <countRange>1~5</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MeleeWeapon_LongSword</thingDef>
        <countRange>1~5</countRange>
      </li>

      <!-- ===== 服装 ===== -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Apparel_FlakVest</thingDef>
        <countRange>2~8</countRange>
      </li>
      <!-- Apparel_FlakHelmet 已移除，原版不存在此 Def -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Apparel_ArmorRecon</thingDef>
        <countRange>1~3</countRange>
      </li>
      <!-- Apparel_ArmorMarine 已移除，部分版本中此 Def 不存在 -->

      <!-- ===== 建筑/家具 ===== -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>OrbitalTradeBeacon</thingDef>
        <countRange>1~3</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>CommsConsole</thingDef>
        <countRange>1~2</countRange>
      </li>

      <!-- ===== 杂项 ===== -->
      <!-- 注意：Neurotrainer_Melee / Neurotrainer_Shooting 需要 Royalty DLC -->
      <!-- 如果未安装 Royalty，请删除或注释以下两行 -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Neurotrainer_Melee</thingDef>
        <countRange>1~2</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>Neurotrainer_Shooting</thingDef>
        <countRange>1~2</countRange>
      </li>
    </stockGenerators>

    <!-- 商店会收购的物品类型 -->
    <!-- 注意：StockGenerator_BuyExpensiveSimple 需要 Royalty DLC -->
    <!-- 如果未安装 Royalty，此条目会导致红字错误，请删除下方行 -->
    <stockGenerators>
      <li Class="StockGenerator_BuyTradeTag">
        <tag>Art</tag>
      </li>
      <li Class="StockGenerator_BuyTradeTag">
        <tag>Drugs</tag>
      </li>
      <li Class="StockGenerator_BuyTradeTag">
        <tag>AnimalPart</tag>
      </li>
      <li Class="StockGenerator_BuyExpensiveSimple" />
    </stockGenerators>
  </TraderKindDef>
</Defs>
