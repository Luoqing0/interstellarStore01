<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     星际商店 - 看板娘配置
     每位看板娘拥有独立贴图与问候语池
     AI 辅助生成

     图片路径说明：
     - 贴图必须放在 Textures/ 下的某个子目录，如 Textures/UI/starstore_mascot.png
     - <texturePath> 中不写 "Textures/" 前缀，也不写文件扩展名
     - 推荐尺寸 512×512 或 1024×1024，尽量为正方形

     多问候语池：
     - <greetings> 下每个 <li> 是一句独立问候语
     - 商店打开时会从对应看板娘的问候语池中随机选取一句
     ============================================================ -->
<Defs>
  <StarStore_MascotDef>
    <defName>StarStore_Mascot_Default</defName>
    <label>默认看板娘</label>
    <texturePath>UI/starstore_mascot</texturePath>
    <greetings>
      <li>欢迎光临星际商店！</li>
      <li>今天需要点什么？</li>
      <li>新货已到，进来看看吧~</li>
    </greetings>
  </StarStore_MascotDef>

  <StarStore_MascotDef>
    <defName>StarStore_Mascot_Robot</defName>
    <label>机械助手</label>
    <texturePath>UI/starstore_mascot_robot</texturePath>
    <greetings>
      <li>系统已上线，等待指令。</li>
      <li>今日汇率已更新。</li>
      <li>检测到殖民地信用良好，欢迎选购。</li>
    </greetings>
  </StarStore_MascotDef>
</Defs>
